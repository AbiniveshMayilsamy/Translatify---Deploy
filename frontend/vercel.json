{
  "outputDirectory": "dist",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://translatify-deploy.onrender.com/api/:path*" },
    { "source": "/outputs/:path*", "destination": "https://translatify-deploy.onrender.com/outputs/:path*" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
