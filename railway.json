{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile"
  },
  "deploy": {
    "startCommand": "gunicorn -w 1 -k eventlet --bind 0.0.0.0:$PORT --timeout 120 app:app",
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/api/languages"
  }
}
